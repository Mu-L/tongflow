# dependencies
node_modules/

# next.js
.next/
out/

# production
build/

# env files
.env
.env.*
!.env.example
.envrc
.env*.local
.dev.vars

# data
data/

# runtime-generated artifacts (build-time from ABI / plugin scan)
.tongflow/

# local feature registry overrides (see docs/feature-registry.md)
.tongflow/features.local.json

# private commercial/legal documents (contracts, order forms, signed agreements)
legal/

# misc
.DS_Store
*.tsbuildinfo
next-env.d.ts

# local Python venv (optional, e.g. pip install modal)
.venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Python test/tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# runtime-installed plugin packages (see docs/plugins.md)
# Anchored to repo root so it does NOT also ignore src/lib/plugins/.
# Keep the directory itself tracked via .gitkeep, but ignore everything in it.
/plugins/*
!/plugins/.gitkeep

.claude/

# Cloud shell extension points: a private shell repo links its own
# implementations into these paths at build time (see src/ext-default/ for
# the open-source defaults). They must never be committed here.
/src/ext/
/src/app/(ext)/
/src/middleware.ts
/src/instrumentation.ts

# Cloud shell build artifacts for serverless targets (linked in at build
# time, like src/ext/ above)
/wrangler.jsonc
/open-next.config.ts
/worker-entry.ts
/.open-next/
/.dev.vars*
/.wrangler/
